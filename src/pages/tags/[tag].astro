---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';
import { SECTIONS } from '../../consts';

export async function getStaticPaths() {
  const all = [];
  for (const s of SECTIONS) {
    const entries = await getCollection(s.id, ({ data }) => !data.draft);
    for (const e of entries) {
      all.push({
        href: `/${s.id}/${e.id}/`,
        title: e.data.title,
        description: e.data.description,
        pubDate: e.data.pubDate,
        sectionLabel: s.label,
        tags: e.data.tags ?? [],
      });
    }
  }
  const tags = new Set(all.flatMap((p) => p.tags));
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: all
        .filter((p) => p.tags.includes(tag))
        .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Base title={`Tagged “${tag}”`} description={`All posts tagged ${tag}.`}>
  <a href="/tags/" class="section-badge">← All tags</a>
  <h1>#{tag}</h1>
  <p class="muted">
    {posts.length} post{posts.length === 1 ? '' : 's'} tagged “{tag}”.
  </p>
  <PostList posts={posts} />
</Base>
