---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SECTIONS } from '../../consts';

const counts = new Map<string, number>();
for (const s of SECTIONS) {
  const entries = await getCollection(s.id, ({ data }) => !data.draft);
  for (const e of entries) {
    for (const t of e.data.tags ?? []) {
      counts.set(t, (counts.get(t) ?? 0) + 1);
    }
  }
}
const tags = [...counts.entries()].sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0])
);
---

<Base title="Tags" description="Browse everything on the blog by topic.">
  <h1>Tags</h1>
  <p class="muted">Browse everything by topic.</p>
  <ul class="tag-cloud">
    {
      tags.map(([tag, count]) => (
        <li>
          <a class="tag" href={`/tags/${tag}/`}>
            {tag} <span class="tag-count">{count}</span>
          </a>
        </li>
      ))
    }
  </ul>
</Base>
