---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostList from '../../components/PostList.astro';
import { SECTIONS } from '../../consts';

export function getStaticPaths() {
  return SECTIONS.map((section) => ({
    params: { section: section.id },
    props: { section },
  }));
}

const { section } = Astro.props;

const entries = await getCollection(section.id, ({ data }) => !data.draft);
const posts = entries
  .map((entry) => ({
    href: `/${section.id}/${entry.id}/`,
    title: entry.data.title,
    description: entry.data.description,
    pubDate: entry.data.pubDate,
  }))
  .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
---

<Base title={section.label} description={section.description}>
  <h1>{section.label}</h1>
  <p class="muted">{section.description}</p>
  {posts.length > 0 ? <PostList posts={posts} /> : <p>Nothing here yet — coming soon.</p>}
</Base>
