---
import { SITE_TITLE, GITHUB_URL, LINKEDIN_URL } from '../consts';
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <p class="footer-links">
      <a href={LINKEDIN_URL}>LinkedIn</a>
      <span class="dot">·</span>
      <a href={GITHUB_URL}>GitHub</a>
      <span class="dot">·</span>
      <a href="/tags/">Tags</a>
      <span class="dot">·</span>
      <a href="/rss.xml">RSS</a>
    </p>
    <p class="colophon">
      © {year} {SITE_TITLE} · Built with Astro · set in Fraunces &amp; Inter.
    </p>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: 3rem;
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.75rem 1.375rem 2.5rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem 1.5rem;
    color: var(--text-muted);
    font-size: 0.88rem;
  }
  .footer-links {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .footer-links a {
    color: var(--text-secondary);
  }
  .footer-links a:hover {
    color: var(--accent);
  }
  .footer-links .dot {
    opacity: 0.5;
  }
  .colophon {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
  }
</style>
