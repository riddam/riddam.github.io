---
import { SITE_TITLE, SECTIONS } from '../consts';

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header>
  <nav>
    <a href="/" class:list={['brand', { active: isActive('/') }]}>{SITE_TITLE}</a>
    <div class="links">
      {
        SECTIONS.map((s) => (
          <a href={`/${s.id}/`} class:list={[{ active: isActive(`/${s.id}/`) }]}>
            {s.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--border);
    background: var(--bg-header);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.85rem 1.375rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 1.5rem;
  }
  .brand {
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1.1rem;
    font-size: 0.92rem;
  }
  .links a {
    color: var(--text-muted);
    font-weight: 500;
  }
  .links a.active {
    color: var(--accent);
    font-weight: 600;
  }
  a:hover {
    text-decoration: none;
    color: var(--accent);
  }
</style>
