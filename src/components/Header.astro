---
import { SITE_TITLE, SECTIONS } from '../consts';

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header>
  <nav>
    <a href="/" class:list={['brand', { active: isActive('/') }]}>{SITE_TITLE}</a>
    <div class="links">
      {
        SECTIONS.map((s) => (
          <a href={`/${s.id}/`} class:list={[{ active: isActive(`/${s.id}/`) }]}>
            {s.label}
          </a>
        ))
      }
      <a href="/about/" class:list={[{ active: isActive('/about') }]}>About</a>
      <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle theme">
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--border);
    background: var(--bg-header);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.9rem 1.375rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1.5rem;
  }
  .brand {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    color: var(--text);
    margin-right: auto;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 1.15rem;
    font-size: 0.94rem;
  }
  .links a {
    color: var(--text-muted);
    font-weight: 500;
  }
  .links a.active {
    color: var(--accent);
    font-weight: 600;
  }
  .links a:hover {
    color: var(--accent);
  }
</style>
