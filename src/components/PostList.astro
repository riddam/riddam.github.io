---
interface PostItem {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  sectionLabel?: string;
}

interface Props {
  posts: PostItem[];
}

const { posts } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<ul class="post-list">
  {
    posts.map((post) => (
      <li>
        {post.sectionLabel && <span class="section-badge">{post.sectionLabel}</span>}
        <div class="post-title">
          <a href={post.href}>{post.title}</a>
        </div>
        <p>{formatDate(post.pubDate)} — {post.description}</p>
      </li>
    ))
  }
</ul>
