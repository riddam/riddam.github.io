---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  GITHUB_URL,
  LINKEDIN_URL,
  AUTHOR_ROLE,
} from '../consts';
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';

interface Props {
  title?: string;
  description: string;
  wide?: boolean;
  ogImage?: string;
  article?: {
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
    section?: string;
    sectionId?: string;
    wordCount?: number;
  };
}

const { title, description, wide = false, ogImage, article } = Astro.props;
const pageTitle = title ? `${title} · ${SITE_TITLE}` : SITE_TITLE;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage ?? '/og/site.png', Astro.site).href;
const ogType = article ? 'article' : 'website';

const person = {
  '@type': 'Person',
  name: SITE_TITLE,
  jobTitle: AUTHOR_ROLE,
  worksFor: { '@type': 'Organization', name: 'Coolblue' },
  url: Astro.site?.href,
  sameAs: [LINKEDIN_URL, GITHUB_URL],
};

const articleLd = article
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      url: canonicalURL.href,
      mainEntityOfPage: canonicalURL.href,
      inLanguage: 'en-US',
      datePublished: article.pubDate.toISOString(),
      dateModified: (article.updatedDate ?? article.pubDate).toISOString(),
      keywords: article.tags?.join(', '),
      ...(article.section ? { articleSection: article.section } : {}),
      ...(article.wordCount ? { wordCount: article.wordCount } : {}),
      author: person,
      publisher: person,
      image: ogImageURL,
    }
  : null;

// Breadcrumb trail (Home › Section › Post) for richer search results.
const breadcrumbLd =
  article && article.sectionId
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: Astro.site?.href },
          {
            '@type': 'ListItem',
            position: 2,
            name: article.section,
            item: new URL(`/${article.sectionId}/`, Astro.site).href,
          },
          { '@type': 'ListItem', position: 3, name: title, item: canonicalURL.href },
        ],
      }
    : null;

const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_TITLE,
  description: SITE_DESCRIPTION,
  url: Astro.site?.href,
  author: person,
};

const jsonLd = article ? [articleLd, breadcrumbLd].filter(Boolean) : websiteLd;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" id="meta-theme-color" content="#faf6ee" />
    <script is:inline>
      // Apply saved theme before paint to avoid a flash, and match the mobile
      // browser chrome (theme-color) to the effective theme.
      const saved = localStorage.getItem('theme');
      if (saved === 'light' || saved === 'dark') document.documentElement.dataset.theme = saved;
      const effective =
        saved === 'light' || saved === 'dark'
          ? saved
          : window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
      document
        .getElementById('meta-theme-color')
        ?.setAttribute('content', effective === 'dark' ? '#16130e' : '#faf6ee');
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE_TITLE} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href={new URL('rss.xml', Astro.site)}
    />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title ?? SITE_TITLE} />
    {
      article && (
        <>
          <meta property="article:published_time" content={article.pubDate.toISOString()} />
          <meta
            property="article:modified_time"
            content={(article.updatedDate ?? article.pubDate).toISOString()}
          />
          <meta property="article:author" content={SITE_TITLE} />
          {article.section && <meta property="article:section" content={article.section} />}
          {article.tags?.map((tag) => <meta property="article:tag" content={tag} />)}
        </>
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={title ?? SITE_TITLE} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class:list={[{ wide }]}>
      <slot />
    </main>
    <Footer />

    <button id="back-to-top" class="back-to-top" type="button" aria-label="Back to top">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 19V5M5 12l7-7 7 7" />
      </svg>
    </button>

    <script>
      // Show a back-to-top button once the reader has scrolled down.
      const toTop = document.getElementById('back-to-top');
      if (toTop) {
        const onScroll = () => {
          toTop.classList.toggle('visible', window.scrollY > 700);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
        toTop.addEventListener('click', () =>
          window.scrollTo({ top: 0, behavior: 'smooth' })
        );
      }
    </script>

    <script>
      // Render mermaid diagrams only on pages that contain them; the library
      // is code-split and never downloaded otherwise.
      const blocks = [...document.querySelectorAll('pre.mermaid')];
      if (blocks.length > 0) {
        const { default: mermaid } = await import('mermaid');
        // Stash each diagram's source so we can re-render on theme change;
        // mermaid replaces the block's contents with an SVG once processed.
        const sources = blocks.map((el) => el.textContent ?? '');
        const isDark = () => {
          const attr = document.documentElement.dataset.theme;
          return attr
            ? attr === 'dark'
            : window.matchMedia('(prefers-color-scheme: dark)').matches;
        };
        const renderDiagrams = async () => {
          blocks.forEach((el, i) => {
            el.removeAttribute('data-processed');
            el.innerHTML = sources[i];
          });
          mermaid.initialize({
            startOnLoad: false,
            theme: isDark() ? 'dark' : 'neutral',
            fontFamily: "'Inter Variable', sans-serif",
          });
          await mermaid.run({ nodes: blocks });
        };
        await renderDiagrams();
        window.addEventListener('themechange', renderDiagrams);
      }
    </script>

    <script>
      // Theme toggle — flips between light and dark, persists the choice.
      const toggle = document.getElementById('theme-toggle');
      if (toggle) {
        const effective = () =>
          document.documentElement.dataset.theme ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        toggle.addEventListener('click', () => {
          const next = effective() === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
          document
            .getElementById('meta-theme-color')
            ?.setAttribute('content', next === 'dark' ? '#16130e' : '#faf6ee');
          window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: next } }));
        });
      }
    </script>

    <script>
      // Add a copy button to every fenced code block.
      for (const pre of document.querySelectorAll('pre.astro-code')) {
        const btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.type = 'button';
        btn.textContent = 'Copy';
        btn.addEventListener('click', async () => {
          const code = pre.querySelector('code')?.innerText ?? pre.innerText;
          try {
            await navigator.clipboard.writeText(code);
            btn.textContent = 'Copied';
            setTimeout(() => (btn.textContent = 'Copy'), 1500);
          } catch {
            btn.textContent = 'Failed';
            setTimeout(() => (btn.textContent = 'Copy'), 1500);
          }
        });
        pre.appendChild(btn);
      }
    </script>
  </body>
</html>
