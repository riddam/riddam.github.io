---
import Base from './Base.astro';
import type { Section } from '../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  section: Section;
  minutesRead?: number;
}

const { title, description, pubDate, updatedDate, tags, section, minutesRead } =
  Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={title} description={description}>
  <article>
    <div class="post-header">
      <a href={`/${section.id}/`} class="section-badge">{section.label}</a>
      <h1>{title}</h1>
      <p class="post-description">{description}</p>
      <p class="post-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {
          updatedDate && (
            <>
              <span class="dot">·</span>
              <span>Updated {formatDate(updatedDate)}</span>
            </>
          )
        }
        {
          minutesRead && (
            <>
              <span class="dot">·</span>
              <span>{minutesRead} min read</span>
            </>
          )
        }
      </p>
      {
        tags.length > 0 && (
          <div class="tags">
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )
      }
    </div>
    <hr />
    <slot />
  </article>
</Base>
