---
import Base from './Base.astro';
import PostList from '../components/PostList.astro';
import {
  SITE_TITLE,
  AUTHOR_ROLE,
  AUTHOR_LOCATION,
  AUTHOR_BLURB,
  LINKEDIN_URL,
  GITHUB_URL,
} from '../consts';
import type { Section } from '../consts';
import type { MarkdownHeading } from 'astro';

interface RelatedPost {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  sectionLabel?: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  section: Section;
  minutesRead?: number;
  wordCount?: number;
  headings?: MarkdownHeading[];
  ogImage?: string;
  related?: RelatedPost[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  section,
  minutesRead,
  wordCount,
  headings = [],
  ogImage,
  related = [],
} = Astro.props;

const tocItems = headings.filter((h) => h.depth === 2);
const showToc = tocItems.length >= 3;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  title={title}
  description={description}
  wide={showToc}
  ogImage={ogImage}
  article={{
    pubDate,
    updatedDate,
    tags,
    section: section.label,
    sectionId: section.id,
    wordCount,
  }}
>
  <div class="reading-progress" id="reading-progress"></div>
  <div class:list={['post-grid', { 'has-toc': showToc }]}>
    <article>
      <div class="post-header">
        <a href={`/${section.id}/`} class="section-badge">{section.label}</a>
        <h1>{title}</h1>
        <p class="post-description">{description}</p>
        <p class="byline">
          By <a href="/about/">{SITE_TITLE}</a> · {AUTHOR_ROLE}
        </p>
        <p class="post-meta">
          <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
          {
            updatedDate && (
              <>
                <span class="dot">·</span>
                <span>Updated {formatDate(updatedDate)}</span>
              </>
            )
          }
          {
            minutesRead && (
              <>
                <span class="dot">·</span>
                <span>{minutesRead} min read</span>
              </>
            )
          }
        </p>
        {
          tags.length > 0 && (
            <div class="tags">
              {tags.map((tag) => (
                <a class="tag" href={`/tags/${tag}/`}>
                  {tag}
                </a>
              ))}
            </div>
          )
        }
      </div>
      <hr class="post-divider" />
      <slot />

      <footer class="author-card">
        <p class="author-name">{SITE_TITLE}</p>
        <p class="author-role">{AUTHOR_ROLE} · {AUTHOR_LOCATION}</p>
        <p class="author-blurb">{AUTHOR_BLURB} If this was useful, let's connect.</p>
        <p class="author-links">
          <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <span class="dot">·</span>
          <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">GitHub</a>
          <span class="dot">·</span>
          <a href="/about/">About</a>
        </p>
      </footer>

      {
        related.length > 0 && (
          <section class="related">
            <h2>Keep reading</h2>
            <PostList posts={related} />
          </section>
        )
      }
    </article>

    {
      showToc && (
        <aside class="toc" aria-label="Table of contents">
          <nav>
            <p class="toc-title">On this page</p>
            <ul>
              {tocItems.map((h) => (
                <li>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )
    }
  </div>
</Base>

<script>
  // Reading progress bar tied to scroll position.
  const bar = document.getElementById('reading-progress');
  if (bar) {
    const update = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
      bar.style.width = pct + '%';
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
  }
</script>

<script>
  // Highlight the TOC entry for the section currently in view. Driven by scroll
  // position (last heading above the offset) so it stays correct scrolling both
  // down and up — an intersection-only approach leaves stale/no active entry.
  const toc = document.querySelector('.toc');
  if (toc) {
    const links = new Map(
      [...toc.querySelectorAll('a')].map((a) => [
        decodeURIComponent(a.hash.slice(1)),
        a,
      ])
    );
    const headings = [...links.keys()]
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    const OFFSET = 100; // account for the sticky header
    const setActive = () => {
      let currentId = headings[0]?.id;
      for (const h of headings) {
        if (h.getBoundingClientRect().top - OFFSET <= 0) currentId = h.id;
        else break;
      }
      links.forEach((a, id) => a.classList.toggle('active', id === currentId));
    };

    setActive();
    window.addEventListener('scroll', setActive, { passive: true });
    window.addEventListener('resize', setActive);
  }
</script>
